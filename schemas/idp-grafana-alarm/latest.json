{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IDP Grafana Alarm Values",
  "type": "object",
  "properties": {
    "idp_aws_account": {
      "anyOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "idp_oidc_provider_url": { "type": "string" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "folder": { "type": "string" },
    "folderRef": { "type": "string" },
    "interval": { "type": "string" },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/definitions/rule" }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "rules"],
        "properties": {
          "name": { "type": "string" },
          "interval": { "type": "string" },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/rule" }
          }
        }
      }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["uid", "title", "condition", "data"],
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "condition": { "type": "string" },
        "for": { "type": "string" },
        "noDataState": {
          "type": "string",
          "enum": ["OK", "Alerting", "NoData"]
        },
        "execErrState": {
          "type": "string",
          "enum": ["OK", "Alerting", "Error"]
        },
        "annotations": { "type": "object" },
        "labels": { "type": "object" },
        "isPaused": { "type": "boolean" },
        "notification_settings": {
          "type": "object",
          "properties": {
            "receiver": { "type": "string" }
          }
        },
        "data": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["refId"],
            "properties": {
              "refId": { "type": "string" },
              "relativeTimeRange": { "type": "object" },
              "datasourceUid": { "type": "string" },
              "model": { "type": "object" }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
