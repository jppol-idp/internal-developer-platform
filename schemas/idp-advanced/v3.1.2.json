            "tcpSocket": {
              "type": "object",
              "properties": {
                "port": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "host": {
                  "type": "string"
                }
              }
            },
            "sleep": {
              "type": "object",
              "properties": {
                "seconds": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "seconds"
              ]
            }
          }
        },
        "postStart": {
          "type": "object",
          "properties": {
            "exec": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "httpGet": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "port": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "scheme": {
                  "type": "string",
                  "enum": [
